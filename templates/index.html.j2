<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{% if gtm_id %}<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','{{ gtm_id }}');</script>
<!-- End Google Tag Manager -->{% endif %}
<title>{{ t.title }}</title>
<meta name="description" content="{{ t.metaDesc }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ t.title }}">
<meta property="og:description" content="{{ t.ogDesc }}">
<meta property="og:url" content="{{ canonical }}">
<meta property="og:locale" content="{{ og_locale }}">
<meta property="og:locale:alternate" content="{{ og_locale_alt }}">
<meta property="og:site_name" content="Everware">
<meta property="og:image" content="{{ site_url }}/assets/og-image.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ t.ogImageAlt }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ t.title }}">
<meta name="twitter:description" content="{{ t.ogDesc }}">
<meta name="twitter:image" content="{{ site_url }}/assets/og-image.png">
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<meta name="theme-color" content="#050505">
{{ jsonld }}
<link rel="canonical" href="{{ canonical }}">
<link rel="alternate" hreflang="nl" href="{{ site_url }}/">
<link rel="alternate" hreflang="en" href="{{ site_url }}/en/">
<link rel="alternate" hreflang="x-default" href="{{ site_url }}/">
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2032%2032'%3E%3Crect%20width='32'%20height='32'%20fill='%23050505'/%3E%3Ctext%20x='16'%20y='23'%20font-family='monospace'%20font-size='20'%20font-weight='700'%20fill='%233B82F6'%20text-anchor='middle'%3EE%3C/text%3E%3C/svg%3E">
<!-- Fonts self-hosted in assets/fonts/ (see @font-face in style.css) — no
     render-blocking third-party request. Preload the hero H1 weight so the LCP
     text (Space Grotesk 700) paints without waiting on the CSS. -->
<link rel="preload" href="{{ asset_prefix }}fonts/space-grotesk-700-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="stylesheet" href="{{ asset_prefix }}{{ css_name }}?v={{ css_v }}">
<script id="ew-main" src="{{ asset_prefix }}{{ js_name }}?v={{ js_v }}" defer></script>
</head>
<body>
{% if gtm_id %}<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ gtm_id }}"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->{% endif %}
<div style="background:#050505;color:#fff;--accent:#3B82F6">

  <!-- ============ FIXED HEADER ============ -->
  <header id="ew-header" style="position:fixed;top:0;left:0;right:0;z-index:200;background:#050505;color:#fff;transition:background .45s ease,color .45s ease;will-change:background,color">
    <div class="ew-nav" style="max-width:1600px;width:100%;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px 60px;box-sizing:border-box">
      <div style="font-weight:700;font-size:20px;letter-spacing:-.02em">Everware</div>
      <div style="display:flex;align-items:center;gap:26px">
        <nav class="ew-navlinks" aria-label="{{ t.navAria }}" style="display:flex;flex-wrap:wrap;gap:12px 26px;font-family:'JetBrains Mono',monospace;font-size:12.5px;letter-spacing:.04em">
          <a class="ew-navlink" data-nav="capaciteiten" href="#capaciteiten">{{ t.nav[0].label }}</a>
          <a class="ew-navlink" data-nav="diensten" href="#diensten">{{ t.nav[1].label }}</a>
          <a class="ew-navlink" data-nav="werkwijze" href="#werkwijze">{{ t.nav[2].label }}</a>
          <a class="ew-navlink" data-nav="over-ons" href="#over-ons">{{ t.nav[3].label }}</a>
          <a class="ew-navlink" data-nav="waarom" href="#waarom">{{ t.nav[4].label }}</a>
          <a class="ew-navlink" data-nav="faq" href="#faq">{{ t.nav[5].label }}</a>
          <a class="ew-navlink" data-nav="contact" href="#contact">{{ t.nav[6].label }}</a>
        </nav>
        <div style="display:flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.04em">
          <a id="ew-lang-nl" class="ew-langbtn" href="{{ nl_href }}" style="text-decoration:none{% if lang == 'nl' %};color:#3B82F6;opacity:1;font-weight:600{% else %};opacity:.5;font-weight:400{% endif %}">NL</a>
          <span style="opacity:.28">/</span>
          <a id="ew-lang-en" class="ew-langbtn" href="{{ en_href }}" style="text-decoration:none{% if lang == 'en' %};color:#3B82F6;opacity:1;font-weight:600{% else %};opacity:.5;font-weight:400{% endif %}">EN</a>
        </div>
      </div>
    </div>
  </header>

  <main>

  <!-- ============ HERO ============ -->
  <section id="ew-hero" data-screen-label="Hero" data-theme="dark" style="position:relative;background:#050505;color:#fff;overflow:hidden;min-height:100vh;display:flex;flex-direction:column">
    <div class="ew-dotgrid" style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.06) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;opacity:1;transition:opacity .8s ease"></div>
    <!-- Interactive 3D galaxy; only activated on capable viewports (see startSpline in main.js). Falls back to the dot grid above. -->
    <spline-viewer id="ew-spline" url="{{ asset_prefix }}spline/scene.splinecode"></spline-viewer>
    <div data-glow data-breathe-only data-base="translate(-50%,-50%)" style="position:absolute;top:44%;left:34%;transform:translate(-50%,-50%);width:900px;height:480px;background:radial-gradient(ellipse at center,color-mix(in srgb,var(--accent,#3B82F6) 30%,transparent),transparent 70%);filter:blur(36px);pointer-events:none"></div>

    <div class="ew-hero-grid" style="position:relative;flex:1;width:100%;max-width:1600px;margin:0 auto;box-sizing:border-box;display:flex;align-items:center;padding:0 60px">
      <div class="ew-hero-inner" style="width:100%;display:grid;grid-template-columns:1fr 340px;grid-template-areas:'title title' 'desc index';gap:34px 64px;align-items:start">
      <div style="grid-area:title;min-width:0;display:flex;flex-direction:column;justify-content:flex-end;min-height:calc(42px + clamp(194.4px,16.2vw,248.4px))">
        <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.28em;color:rgba(255,255,255,.42);text-transform:uppercase;margin-bottom:26px">{{ t.heroEyebrow }}</div>
        <h1 class="ew-hero-h1" style="margin:0;font-weight:700;font-size:clamp(108px,9vw,138px);line-height:.9;letter-spacing:-.035em;display:flex;flex-wrap:wrap;align-items:baseline;column-gap:22px;row-gap:0">
          <span id="ew-title" style="text-shadow:0 0 40px rgba(255,255,255,.22),0 0 90px rgba(255,255,255,.1)">{{ t.heroTitleWord }}</span>
          <span id="ew-group" style="display:inline-flex;align-items:baseline;gap:13px">
            <span class="ew-bracket">[</span><span id="ew-typed" data-words='{{ t.words | tojson }}' style="color:#3B82F6;display:inline-block;text-shadow:0 0 30px #3B82F699,0 0 72px #3B82F666">AI</span><span class="ew-bracket">]</span>
            <span class="ew-cursor" style="width:32px;height:74px;background:var(--accent,#3B82F6);display:inline-block;box-shadow:0 0 26px color-mix(in srgb,var(--accent,#3B82F6) 70%,transparent);animation:blink 1.1s steps(1) infinite;transform:translateY(6px)"></span>
          </span>
        </h1>
      </div>
      <div style="grid-area:desc;min-width:0">
        <p style="max-width:560px;margin:0;font-size:18px;line-height:1.5;color:rgba(255,255,255,.6)">{{ t.heroDesc }}</p>
        <div style="margin-top:34px;display:inline-flex;align-items:center;gap:12px">
          <a class="ew-hero-cta" href="#contact" style="text-decoration:none;background:var(--accent,#3B82F6);color:#fff;font-weight:600;font-size:15px;padding:14px 26px;border-radius:999px;box-shadow:0 0 30px color-mix(in srgb,var(--accent,#3B82F6) 45%,transparent)">{{ t.heroCta1 }}</a>
          <a class="ew-hero-cta" href="#werkwijze" style="text-decoration:none;color:rgba(255,255,255,.7);font-weight:500;font-size:15px;padding:14px 8px">{{ t.heroCta2 }}</a>
        </div>
      </div>
      <div class="ew-hero-index" style="grid-area:index;font-family:'JetBrains Mono',monospace;font-size:12.5px;border-bottom:1px solid rgba(255,255,255,.14);margin-top:8px">
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">01</span><span>{{ t.heroIndex[0].label }}</span></a>
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">02</span><span>{{ t.heroIndex[1].label }}</span></a>
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">03</span><span>{{ t.heroIndex[2].label }}</span></a>
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">04</span><span>{{ t.heroIndex[3].label }}</span></a>
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">05</span><span>{{ t.heroIndex[4].label }}</span></a>
        <a class="ew-ixlink" href="#diensten"><span class="ew-accent">0A</span><span>{{ t.heroIndex[5].label }}</span></a>
      </div>
      </div>
    </div>

    <div style="position:relative;border-top:1px solid rgba(255,255,255,.14);background:#050505">
      <div class="ew-status" style="max-width:1600px;margin:0 auto;box-sizing:border-box;display:flex;align-items:center;justify-content:space-between;gap: 22px;padding:18px 60px;font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.55)">
        <span>Everware</span>
        <span class="ew-metrics" style="display:flex;gap:22px">
          {% for s in t.status %}<span class="ew-status-item"><span class="ew-accent">/</span><span>{{ s }}</span></span>{% endfor %}
        </span>
      </div>
    </div>
  </section>

  <!-- ============ CAPABILITIES (white) ============ -->
  <section id="capaciteiten" data-screen-label="Capaciteiten" data-theme="light" class="ew-sec-light">
    <div data-glow data-base="rotate(-18deg)" style="position:absolute;top:15%;left:-11%;width:56%;height:40%;transform:rotate(-18deg);background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 45%,color-mix(in srgb,var(--accent,#3B82F6) 70%,transparent) 50%,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 55%,transparent);filter:blur(60px);opacity:.5;pointer-events:none"></div>
    <div class="ew-pad ew-grid2 ew-grid2w">
      <div>
        <div class="ew-eyebrow-l">{{ t.capEyebrow }}</div>
        <h2 class="ew-sec-h2">{{ t.capH2 }}</h2>
        <p style="max-width:440px;margin:28px 0 0;font-size:18px;line-height:1.55;color:rgba(0,0,0,.62)">{{ t.capLead }}</p>
        <div style="display:flex;gap:11px;margin-top:34px;font-family:'JetBrains Mono',monospace;flex-wrap:wrap">
          <span class="ew-pill">{{ t.capTags[0] }}</span>
          <span class="ew-pill">{{ t.capTags[1] }}</span>
          <span class="ew-pill">{{ t.capTags[2] }}</span>
        </div>
      </div>
      <div style="font-family:'JetBrains Mono',monospace;border-bottom:1px solid rgba(0,0,0,.16)">
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[0].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[0].lines[0] }}</span><span class="ew-b">{{ t.capRows[0].lines[1] }}</span></span>
        </div>
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[1].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[1].lines[0] }}</span><span class="ew-b">{{ t.capRows[1].lines[1] }}</span><span class="ew-b">{{ t.capRows[1].lines[2] }}</span></span>
        </div>
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[2].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[2].lines[0] }}</span><span class="ew-b">{{ t.capRows[2].lines[1] }}</span></span>
        </div>
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[3].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[3].lines[0] }}</span></span>
        </div>
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[4].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[4].lines[0] }}</span></span>
        </div>
        <div class="ew-caprow">
          <span class="ew-caplabel">{{ t.capRows[5].label }}</span>
          <span class="ew-capval"><span class="ew-b">{{ t.capRows[5].lines[0] }}</span><span class="ew-b">{{ t.capRows[5].lines[1] }}</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES (black) ============ -->
  <section id="diensten" data-screen-label="Diensten" data-theme="dark" class="ew-sec-dark">
    <!-- Static starfield over the black backdrop; painted by startStarfields in main.js (skipped under reduced-motion). -->
    <canvas class="ew-stars" aria-hidden="true"></canvas>
    <div data-glow data-base="none" style="position:absolute;top:27%;right:-2%;width:760px;height:560px;background:radial-gradient(ellipse at center,color-mix(in srgb,var(--accent,#3B82F6) 22%,transparent),transparent 70%);filter:blur(40px);pointer-events:none"></div>
    <div class="ew-pad">
      <div class="ew-eyebrow-hero">{{ t.svEyebrow }}</div>
      <h2 class="ew-sec-h2 ew-sec-h2-mb">{{ t.svH2 }}</h2>
      <div class="ew-grid2" style="display:grid;grid-template-columns:1fr 1fr;gap:22px">
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[0].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[0].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[0].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[0].meta }}</div>
        </div>
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[1].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[1].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[1].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[1].meta }}</div>
        </div>
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[2].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[2].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[2].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[2].meta }}</div>
        </div>
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[3].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[3].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[3].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[3].meta }}</div>
        </div>
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[4].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[4].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[4].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[4].meta }}</div>
        </div>
        <div class="ew-card">
          <div class="ew-svc-num">{{ t.svCards[5].level }}</div>
          <h3 class="ew-svc-h3">{{ t.svCards[5].title }}</h3>
          <p class="ew-svc-p">{{ t.svCards[5].desc }}</p>
          <div class="ew-eyebrow-d">{{ t.svCards[5].meta }}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WERKWIJZE (white) ============ -->
  <section id="werkwijze" data-screen-label="Werkwijze" data-theme="light" class="ew-sec-light">
    <div data-glow data-base="rotate(-18deg)" style="position:absolute;bottom:12%;right:4%;width:56%;height:40%;transform:rotate(-18deg);background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 45%,color-mix(in srgb,var(--accent,#3B82F6) 70%,transparent) 50%,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 55%,transparent);filter:blur(60px);opacity:.5;pointer-events:none"></div>
    <div class="ew-pad">
      <div class="ew-eyebrow-l">{{ t.wpEyebrow }}</div>
      <h2 class="ew-sec-h2" style="margin:0 0 64px;max-width:820px">{{ t.wpH2 }}</h2>
      <div class="wp-track">
        <div class="wp-line wp-line-base"></div>
        <div class="wp-line wp-line-fill"></div>
        <div class="wp-grid">
          {% for step in t.wpSteps %}
          <div class="wp-node">
            <div class="wp-dotrow">
              {% if loop.last %}
              <svg class="wp-loop" viewBox="0 0 44 44" fill="none" aria-hidden="true">
                <path d="M 30.9 35.5 A 17 17 0 1 0 13.1 35.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                <path d="M 15.8 37.2 L 9.4 37.2 L 13.0 31.4 Z" fill="currentColor"></path>
              </svg>
              {% endif %}
              <div class="wp-dot"></div>
            </div>
            <div class="wp-body">
              <div class="wp-n">{{ step.n }}</div>
              <h3>{{ step.title }}</h3>
              <p>{{ step.desc }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OVER ONS (black) ============ -->
  <section id="over-ons" data-screen-label="Over ons" data-theme="dark" class="ew-sec-dark">
    <!-- Static starfield over the black backdrop; painted by startStarfields in main.js (skipped under reduced-motion). -->
    <canvas class="ew-stars" aria-hidden="true"></canvas>
    <div data-glow data-base="none" style="position:absolute;top:20%;left:-4%;width:720px;height:520px;background:radial-gradient(ellipse at center,color-mix(in srgb,var(--accent,#3B82F6) 20%,transparent),transparent 70%);filter:blur(42px);pointer-events:none"></div>
    <div class="ew-pad ew-grid2 ew-grid2w">
      <div>
        <div class="ew-eyebrow-hero">{{ t.abEyebrow }}</div>
        <h2 class="ew-sec-h2">{{ t.abH2 }}</h2>
        <p class="ew-sec-lead">{{ t.abParas[0] }}</p>
        <p class="ew-sec-lead">{{ t.abParas[1] }}</p>
      </div>
      <div class="ew-mono">
        {% for row in t.abRows %}<div class="ew-inforow">
          <span class="ew-caplabel">{{ row.label }}</span>
          <span class="ew-inforow-val">{% for line in row.lines %}<span class="ew-b">{{ line }}</span>{% endfor %}</span>
        </div>{% endfor %}
        <div class="ew-inforow"><span class="ew-caplabel">KvK</span><span class="ew-inforow-val">89042786</span></div>
        <div class="ew-inforow"><span class="ew-caplabel">{{ t.abTelLabel }}</span><a href="tel:+31732089198" class="ew-inforow-vallink">073 208 9198</a></div>
        <div style="border-top:1px solid rgba(255,255,255,.14);border-bottom:1px solid rgba(255,255,255,.14);padding:20px 0;display:flex;justify-content:space-between;gap:24px"><span class="ew-caplabel">{{ t.abEmailLabel }}</span><a href="mailto:hallo@everware.nl" class="ew-inforow-vallink">hallo@everware.nl</a></div>
      </div>
    </div>
  </section>

  <!-- ============ WAAROM (accent) ============ -->
  <section id="waarom" data-screen-label="Waarom" data-theme="dark" style="position:relative;overflow:hidden;background:radial-gradient(130% 100% at 22% -12%,color-mix(in srgb,#3B82F6 93%,#ffffff) 0%,#3B82F6 48%,color-mix(in srgb,#3B82F6 92%,#000000) 100%);color:var(--wfg,#fff);--wfg:#fff;--wmut:rgba(255,255,255,.72);--wlead:rgba(255,255,255,.85);--wa-bd:rgba(255,255,255,.3);--wa-bg:rgba(0,0,0,.14);--wa-tt:rgba(255,255,255,.72);--wa-tx:rgba(255,255,255,.75);--wa-mk:rgba(255,255,255,.5);--wb-bd:rgba(255,255,255,.7);--wb-bg:rgba(255,255,255,.16);--wb-tt:#ffffff;--wb-tx:#ffffff;--wb-mk:#ffffff;--wglow:rgba(0,0,0,.24)">
    <div data-glow data-parallax="-0.4" data-base="translateY(-50%)" style="position:absolute;top:66%;right:14%;transform:translateY(-50%);width:620px;height:460px;background:radial-gradient(ellipse at center,var(--wglow,color-mix(in srgb,var(--accent,#3B82F6) 16%,transparent)),transparent 70%);filter:blur(48px);pointer-events:none"></div>
    <div class="ew-pad">
      <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.28em;text-transform:uppercase;color:var(--wmut,rgba(255,255,255,.42));margin-bottom:26px">{{ t.whyEyebrow }}</div>
      <h2 class="ew-sec-h2" style="font-size:52px;line-height:1.02;max-width:900px">{{ t.whyH2 }}</h2>
      <p style="max-width:620px;margin:28px 0 0;font-size:18px;line-height:1.55;color:var(--wlead,rgba(255,255,255,.62))">{{ t.whyLead }}</p>
      <div class="ew-why ew-grid2" style="margin-top:56px;display:grid;grid-template-columns:0.9fr 1.1fr;gap:22px">
        <div style="border:1px solid var(--wa-bd,rgba(255,255,255,.12));border-radius:16px;padding:34px;background:var(--wa-bg,rgba(0,0,0,.18))">
          <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--wa-tt,rgba(255,255,255,.4));margin-bottom:24px">{{ t.whyColATitle }}</div>
          <div class="ew-col16">
            <div class="ew-why-a"><span class="ew-why-mk-a">✕</span><span>{{ t.whyColA[0] }}</span></div>
            <div class="ew-why-a"><span class="ew-why-mk-a">✕</span><span>{{ t.whyColA[1] }}</span></div>
            <div class="ew-why-a"><span class="ew-why-mk-a">✕</span><span>{{ t.whyColA[2] }}</span></div>
            <div class="ew-why-a"><span class="ew-why-mk-a">✕</span><span>{{ t.whyColA[3] }}</span></div>
            <div class="ew-why-a"><span class="ew-why-mk-a">✕</span><span>{{ t.whyColA[4] }}</span></div>
          </div>
        </div>
        <div style="border:1px solid var(--wb-bd,color-mix(in srgb,var(--accent,#3B82F6) 45%,transparent));border-radius:16px;padding:34px;background-color:#FFFFFF1A">
          <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--wb-tt,var(--accent,#3B82F6));margin-bottom:24px">{{ t.whyColBTitle }}</div>
          <div class="ew-col16">
            <div class="ew-why-b"><span class="ew-why-mk-b">→</span><span>{{ t.whyColB[0] }}</span></div>
            <div class="ew-why-b"><span class="ew-why-mk-b">→</span><span>{{ t.whyColB[1] }}</span></div>
            <div class="ew-why-b"><span class="ew-why-mk-b">→</span><span>{{ t.whyColB[2] }}</span></div>
            <div class="ew-why-b"><span class="ew-why-mk-b">→</span><span>{{ t.whyColB[3] }}</span></div>
            <div class="ew-why-b"><span class="ew-why-mk-b">→</span><span>{{ t.whyColB[4] }}</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ (white) ============ -->
  <section id="faq" data-screen-label="FAQ" data-theme="light" class="ew-sec-light">
    <div data-glow data-base="rotate(-18deg)" style="position:absolute;top:23%;right:-8%;width:52%;height:38%;transform:rotate(-18deg);background:linear-gradient(90deg,transparent,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 45%,color-mix(in srgb,var(--accent,#3B82F6) 70%,transparent) 50%,color-mix(in srgb,var(--accent,#3B82F6) 55%,transparent) 55%,transparent);filter:blur(60px);opacity:.45;pointer-events:none"></div>
    <div class="ew-pad">
      <div class="ew-eyebrow-l">{{ t.faqEyebrow }}</div>
      <h2 class="ew-sec-h2 ew-sec-h2-mb">{{ t.faqH2 }}</h2>
      <div class="faq-acc">
        {% for f in t.faqItems %}
        <div class="faq-item{% if loop.first %} open{% endif %}">
          <button class="faq-q" type="button" aria-expanded="{{ 'true' if loop.first else 'false' }}">
            <h3>{{ f.q }}</h3><span class="faq-mark">+</span>
          </button>
          <div class="faq-a"><div><p>{{ f.a }}</p></div></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  </main>

  <!-- Contact + footer sit over ONE continuous starfield; painted by startStarfields in main.js (skipped under reduced-motion). -->
  <div class="ew-starfield" style="position:relative;background:#050505">
  <canvas class="ew-stars" aria-hidden="true"></canvas>

  <!-- ============ CONTACT (black) ============ -->
  <section id="contact" data-screen-label="Contact" data-theme="dark" style="position:relative;color:#fff;overflow:hidden">
    <div data-glow data-parallax=".05" data-base="none" style="position:absolute;top:-2%;left:3%;width:820px;height:520px;background:radial-gradient(ellipse at center,color-mix(in srgb,var(--accent,#3B82F6) 40%,transparent),transparent 68%);filter:blur(46px);pointer-events:none"></div>

    <div class="ew-contact-pad" style="position:relative;max-width:1240px;margin:0 auto;box-sizing:border-box;padding:130px 48px 0;text-align:center">
      <h2 class="ew-contact-h1" style="margin:0;font-weight:700;font-size:92px;line-height:.92;letter-spacing:-.035em;text-shadow:0 0 40px rgba(255,255,255,.2),0 0 90px rgba(255,255,255,.1)">{{ t.ctH2 }}</h2>
      <p style="max-width:540px;margin:30px auto 0;font-size:18px;line-height:1.55;color:rgba(255,255,255,.6)">{{ t.ctLead }}</p>
      <div style="max-width:640px;margin:46px auto 0;text-align:left">
        <form id="ew-form" style="display:grid;gap:20px">
          <input type="text" name="website" value="" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:0;height:0;opacity:0">
          <div class="ew-form2" style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
            <label class="ew-b">
              <span class="ew-stat-label">{{ t.ctNaam }}</span>
              <input class="ew-input" type="text" name="name" required minlength="2" placeholder="{{ t.ctNaamPh }}">
            </label>
            <label class="ew-b">
              <span class="ew-stat-label">{{ t.ctEmail }}</span>
              <input class="ew-input" type="email" name="email" required placeholder="{{ t.ctEmailPh }}">
            </label>
          </div>
          <label class="ew-b">
            <span class="ew-stat-label"><span>{{ t.ctBedrijf }}</span> <span style="color:rgba(255,255,255,.28)">{{ t.ctBedrijfOpt }}</span></span>
            <input class="ew-input" type="text" name="company" placeholder="{{ t.ctBedrijfPh }}">
          </label>
          <label class="ew-b">
            <span class="ew-stat-label">{{ t.ctIdea }}</span>
            <textarea class="ew-input" name="message" required minlength="10" rows="4" placeholder="{{ t.ctIdeaPh }}" style="line-height:1.5;resize:vertical"></textarea>
          </label>
          <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;margin-top:4px">
            <button id="ew-submit" type="submit" class="ew-submit" style="border:none;cursor:pointer;background:var(--accent,#3B82F6);color:#fff;font-weight:600;font-size:15px;font-family:'Space Grotesk',sans-serif;padding:15px 30px;border-radius:999px;box-shadow:0 0 30px color-mix(in srgb,var(--accent,#3B82F6) 45%,transparent)">{{ t.ctSubmit }}</button>
            <span style="font-family:'JetBrains Mono',monospace;font-size:12.5px;color:rgba(255,255,255,.45)"><span>{{ t.ctOrPre }}</span> <a href="mailto:hallo@everware.nl" class="ew-accent-link">hallo@everware.nl</a> <span>{{ t.ctOrMid }}</span> <a href="tel:+31732089198" class="ew-accent-link">073 208 9198</a></span>
          </div>
          <p id="ew-form-err" role="alert" style="display:none;margin:0;font-size:14px;color:#f87171">{{ t.ctErr }}</p>
          <p style="margin:2px 0 0;font-family:'JetBrains Mono',monospace;font-size:11.5px;line-height:1.5;color:rgba(255,255,255,.35)">{{ t.ctAvg }}</p>
        </form>
        <div id="ew-sent" style="display:none;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.03);border-radius:16px;padding:48px 40px;text-align:center">
          <div style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent,#3B82F6)">{{ t.ctSentTag }}</div>
          <p style="font-size:24px;font-weight:600;letter-spacing:-.02em;margin:16px 0 8px">{{ t.ctSentTitle }}</p>
          <p style="font-size:16px;line-height:1.55;color:rgba(255,255,255,.6);margin:0">{{ t.ctSentBody }}</p>
          <button id="ew-again" type="button" style="margin-top:26px;cursor:pointer;background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.75);font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;text-transform:uppercase;padding:11px 20px;border-radius:999px">{{ t.ctAgain }}</button>
        </div>
      </div>
    </div>
  </section>

  <footer style="position:relative;margin-top:120px;border-top:1px solid rgba(255,255,255,.14)">
      <div style="max-width:1240px;margin:0 auto;box-sizing:border-box;padding:60px 48px 0">
        <div class="ew-footer-grid" style="display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:44px">
          <div>
            <div style="font-weight:700;font-size:22px;letter-spacing:-.02em">Everware</div>
            <p style="max-width:300px;margin:14px 0 0;font-size:14.5px;line-height:1.55;color:rgba(255,255,255,.5)">{{ t.ftTagline }}</p>
            <p style="max-width:300px;margin:16px 0 0;font-size:14.5px;line-height:1.55;color:rgba(255,255,255,.5)">{{ t.ftTripleTimePre }}<a class="ew-accent-link" href="https://tripletime.site" target="_blank" rel="noopener">TripleTime</a>{{ t.ftTripleTimePost }}</p>
          </div>
          <div class="ew-mono">
            <div class="ew-kicker">{{ t.ftContactHd }}</div>
            <div class="ew-col11">
              <a class="ew-ftlink" href="mailto:hallo@everware.nl">hallo@everware.nl</a>
              <a class="ew-ftlink" href="tel:+31732089198">073 208 9198</a>
              <span style="color:rgba(255,255,255,.5)">KvK 89042786</span>
            </div>
          </div>
          <div class="ew-mono">
            <div class="ew-kicker">{{ t.ftNavHd }}</div>
            <div class="ew-col11">
              <a class="ew-ftlink" href="#capaciteiten">{{ t.nav[0].label }}</a>
              <a class="ew-ftlink" href="#diensten">{{ t.nav[1].label }}</a>
              <a class="ew-ftlink" href="#werkwijze">{{ t.nav[2].label }}</a>
              <a class="ew-ftlink" href="#over-ons">{{ t.nav[3].label }}</a>
              <a class="ew-ftlink" href="#waarom">{{ t.nav[4].label }}</a>
              <a class="ew-ftlink" href="#faq">{{ t.nav[5].label }}</a>
              <a class="ew-ftlink" href="#contact">{{ t.nav[6].label }}</a>
            </div>
          </div>
        </div>
        <div style="margin-top:56px;border-top:1px solid rgba(255,255,255,.12);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:22px 0;font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.45)">
          <span>{{ t.ftCopyLeft }}</span>
          <span>{{ t.ftCopyRight }}</span>
        </div>
      </div>
    </footer>
  </div>

</div>
</body>
</html>