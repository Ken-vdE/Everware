# Resend API key (https://resend.com/api-keys) — never commit the real one
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO=hallo@everware.nl

# Verified sender in Resend; onboarding@resend.dev works for testing
CONTACT_FROM=onboarding@resend.dev

# Optional: directory for rotating log files (default: ./logs)
#LOG_DIR=logs

# Base URL used in canonical/og/hreflang links and JSON-LD (no trailing slash).
# Default: https://everware.nl — set this on staging, e.g. https://staging.everware.nl
#SITE_URL=https://everware.nl
